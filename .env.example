# ╔══════════════════════════════════════════════════════════════════╗
# ║           Nexara Agent V1 — Environment Configuration           ║
# ║                  Copy to .env and fill in values                ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Required ──────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_bot_token_from_botfather

# Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=your_telegram_user_id


# ── Agent ─────────────────────────────────────────────────────────────────────
NEXARA_VERSION=1.0.0


# ── LLM Router ────────────────────────────────────────────────────────────────
# Which provider to try first: groq | gemini | nvidia | ollama
PRIMARY_PROVIDER=groq

# Provider 1 — Groq (fastest, recommended primary)
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Provider 2 — Gemini (generous free tier, good fallback)
# Get key: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-1.5-flash

# Provider 3 — NVIDIA NIM (free credits on signup)
# Get key: https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Provider 4 — Ollama (local/offline, no key needed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3


# ── Skills Warehouse ──────────────────────────────────────────────────────────
# Release channel: stable | beta | dev
SKILL_CHANNEL=stable

# Override warehouse URL — leave blank to use official NexaraAI warehouse
# https://github.com/NexaraAI/nexara-skills
SKILL_WAREHOUSE_URL=


# ── Agent OTA Auto-Updater ────────────────────────────────────────────────────
# Raw GitHub URL of your nexara-agent repo root.
# When set, /update fetches agent_manifest.json, diffs SHA256 checksums,
# downloads only changed core files, verifies them, and restarts in place.
# No SSH, no manual editing — just push to GitHub and run /update.
AGENT_REPO_URL=https://raw.githubusercontent.com/NexaraAI/Nexara-agent/main


# ── Optional Skill Integrations ───────────────────────────────────────────────
# Only required if you use these specific skills.

# NewsAPI — core/news skill (falls back to BBC RSS feed if empty)
# Get key: https://newsapi.org
NEWSAPI_KEY=

# Email / SMTP — core/email_send skill
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=you@gmail.com

# Slack webhook — comms/slack_send skill
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Discord webhook — comms/discord_send skill
# Create at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ntfy.sh push notifications — comms/ntfy_send skill
# https://ntfy.sh — self-host or use the public server
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=

# SSH execution — linux/ssh_exec skill
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=~/.ssh/id_rsa

# Git operations — core/git_ops skill
# Personal access token with repo scope
GITHUB_TOKEN=


# ── Downloads ─────────────────────────────────────────────────────────────────
# Max file size for the download skill (GB)
MAX_DOWNLOAD_SIZE_GB=2.0


# ── Platform (auto-set by start.sh — do not edit manually) ───────────────────
# TERMUX_API_AVAILABLE=1
