# Nexara Agent V1.0 — Production Architecture Config
# Copy this file to .env and fill in your values.

# ── Required Bot Settings ────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_from_botfather
ADMIN_ID=your_telegram_user_id

# ── Agent Architecture ───────────────────────────────────────
NEXARA_VERSION=1.0.0
# Options: chat (simple responses) | agent (react loop)
DEFAULT_MODE=agent 

# ── LLM Router (4-Provider Chain) ────────────────────────────
# Which provider to try first. Options: groq | gemini | nvidia | ollama
PRIMARY_PROVIDER=groq

# Provider 1: Groq (Primary / Fastest)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Provider 2: Gemini (Fallback 1 / Generous Free Tier)
LLM_API_KEY=your_gemini_api_key
LLM_MODEL=gemini-1.5-flash

# Provider 3: NVIDIA NIM (Fallback 2 / Free Credits)
NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Provider 4: Ollama (Fallback 3 / Local Offline)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Skill Integrations (Optional) ────────────────────────────
# Only required if you intend to use the specific skills.

# NewsAPI (core/news) — Falls back to BBC RSS if empty
NEWSAPI_KEY=

# Email / SMTP (core/email_send)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# Comms Webhooks (comms/slack_send, comms/discord_send)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ── Warehouse & Skills ───────────────────────────────────────
# Release channel for dynamic skills: stable | beta | dev
SKILL_CHANNEL=stable
# Leave blank to use the official GitHub repository
SKILL_WAREHOUSE_URL=

# ── Automatically set by start.sh (Do not modify) ────────────
# TERMUX_API_AVAILABLE=1
# NEXARA_PASS_PIPE=/tmp/nexara_pass_12345
